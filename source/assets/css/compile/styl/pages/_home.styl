body
    font-weight 400
    min-height 100vh
    font-style normal
    font-optical-sizing auto
    font-family $displayFont
    background linear-gradient(135deg, #667eea 0%, #764ba2 100%)

.form-section
    padding 2rem
    border-radius 12px
    margin-bottom 2rem
    background-color white
    box-shadow 0 10px 40px rgba(0, 0, 0, 0.2)

.fieldset
    margin-bottom 1.5rem

label
    display block
    color $darkGrey
    font-weight 600
    font-size rem(18)
    margin-bottom rem(10)

.label-container
    display flex
    justify-content space-between
    align-items center
    margin-bottom rem(10)

textarea, input[type="number"]
    width 100%
    padding rem(16)
    font-size rem(18)
    font-family inherit
    border-radius rem(8)
    border 2px solid #e0e0e0
    transition border-color 0.3s
    &:focus
        outline none
        border-color #667eea

textarea
    resize vertical
    min-height rem(120)

.form-group
    gap rem(16)
    display grid
    grid-template-columns 1fr 1fr

button
    width 100%
    color white
    border none
    cursor pointer
    padding rem(16)
    font-weight 600
    font-size rem(18)
    border-radius rem(8)
    transition transform 0.2s, box-shadow 0.2s
    background linear-gradient(135deg, #667eea 0%, #764ba2 100%)
    &:hover
        transform translateY(-2px)
        box-shadow 0 8px 20px rgba(102, 126, 234, 0.4)
    &:active
        transform translateY(0)

.error
    color #e74c3c
    font-size 0.9rem
    margin-top 0.5rem

.card--results
    display none
    &.show
        display block

.team
    padding 1.5rem
    border-radius 8px
    background #f8f9fa
    margin-bottom rem(16)
    border-left 4px solid #667eea
    h3
        color #667eea
        font-size 1.1rem
        margin-bottom 0.75rem
    ul
        list-style none
    li
        padding 0.5rem 0
        color #555
        padding-left 1.5rem
        position relative
        &:before
            left 0
            content "→"
            color #667eea
            font-weight bold
            position absolute

.back-button
    background #95a5a6
    margin-top 1rem
    &:hover
        box-shadow 0 8px 20px rgba(149, 165, 166, 0.4)

.hint
    color #999
    font-size 0.85rem
    margin-top 0.35rem

.clear-names-btn
    width auto
    padding 0.4rem 0.8rem
    font-size 1rem
    background #e74c3c
    border-radius 6px
    cursor pointer
    transition all 0.2s
    color white
    border none
    &:hover
        background #c0392b
        transform scale(1.05)
    &:active
        transform scale(0.95)